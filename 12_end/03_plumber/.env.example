# Copy to .env at the repository root before running R scripts like:
# - Rscript 12_end/03_plumber/deployme.R
# - Rscript 12_end/03_plumber/testme.R
#
# These scripts call readRenviron(".env"), which resolves from current working directory.

# Posit Connect base URL (for example: https://connect.example.com)
CONNECT_SERVER=https://connect.example.com
# Posit Connect API key
CONNECT_API_KEY=replace-with-your-connect-api-key
# Optional app title override
CONNECT_TITLE=brussels-traffic-plumber
# Optional for testme.py
API_PUBLIC_URL=http://localhost:8000
