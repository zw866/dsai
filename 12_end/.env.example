# Copy this file to .env at the repository root (or inside 12_end, then load manually).
# Used by:
# - 12_end/03_plumber/deployme.R
# - 12_end/03_plumber/testme.R
# - 12_end/04_agent_query.R

# Public URL of your deployed/local prediction API
API_PUBLIC_URL=http://localhost:8000

# Posit Connect base URL for deployment (R Plumber deploy script)
CONNECT_SERVER=https://connect.example.com

# Optional app title for deployments
CONNECT_TITLE=brussels-traffic-plumber

# Ollama Cloud settings for 04_agent_query.R
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=replace-with-your-ollama-api-key
OLLAMA_MODEL=gpt-oss:20b-cloud