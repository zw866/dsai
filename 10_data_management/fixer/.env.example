# Ollama Cloud (same variables as agentr)
OLLAMA_API_KEY=
OLLAMA_HOST=https://ollama.com
# Use a model that supports tool calling (fixer_csv.R, fixer_parcels.R, fixer_pois.R)
OLLAMA_MODEL=nemotron-3-nano:30b-cloud

# Optional: cap output tokens (omit on Ollama Cloud if requests return HTTP 400)
# FIXER_MAX_OUTPUT_TOKENS=2048

# Batched scripts — rows per chunk (one API call per chunk) and parallel chunk workers
# Applies to fixer_csv.R, fixer_parcels.R, fixer_pois.R, fixer_spatial_context.R
# ROWS_PER_BATCH=10
# FIXER_CHUNK_WORKERS=1

# fixer_spatial_context.R — optional overrides (defaults: output/parcels_enriched.csv + output/pois_enriched.csv)
# FIXER_CONTEXT_PARCELS=C:/path/to/parcels_enriched.csv
# FIXER_CONTEXT_POIS=C:/path/to/pois_enriched.csv
